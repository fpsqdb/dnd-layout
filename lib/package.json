{
    "name": "dnd-layout",
    "version": "0.2.0",
    "description": "A drag-and-drop layout system for React.",
    "license": "MIT",
    "author": "fpsqdb",
    "type": "module",
    "module": "./esm/index.js",
    "main": "./lib/index.js",
    "types": "./esm/index.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/fpsqdb/dnd-layout.git"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [
        "dnd",
        "drag",
        "drop",
        "layout",
        "react",
        "grid"
    ],
    "scripts": {
        "postinstall": "npx playwright install chromium --with-deps",
        "lint": "biome lint",
        "build": "rimraf dist && npm run tsc-cjs && npm run tsc-esm && npm run build-types && node ./build.mjs && rimraf esm",
        "tsc-cjs": "tsc -p ./tsconfigs/tsconfig.production.cjs.json",
        "tsc-esm": "tsc -p ./tsconfigs/tsconfig.production.esm.json",
        "build-types": "npm run build-temp-types && npm run rollup-types",
        "build-temp-types": "tsc --emitDeclarationOnly --outDir temp/ -p ./tsconfigs/tsconfig.declaration.json",
        "rollup-types": "api-extractor run && rimraf temp"
    },
    "dependencies": {
        "use-sync-external-store": "^1.6.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@microsoft/api-extractor": "^7.57.6",
        "@types/node": "^24.11.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/use-sync-external-store": "^1.5.0",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/browser": "^4.0.17",
        "@vitest/browser-playwright": "^4.0.17",
        "@vitest/coverage-v8": "^4.0.18",
        "globals": "^17.4.0",
        "playwright": "^1.58.2",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "rimraf": "^6.1.3",
        "typescript": "~5.9.3",
        "vitest": "^4.0.18",
        "vitest-browser-commands": "^0.2.0",
        "vitest-browser-react": "^2.0.5"
    },
    "peerDependencies": {
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0"
    }
}
